{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fusion-td",
  "main": "worker/index.ts",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "fusion-td-leaderboard",
      "database_id": "7a3d8834-18bb-467b-abb8-295e2707558d"
    }
  ]
}
